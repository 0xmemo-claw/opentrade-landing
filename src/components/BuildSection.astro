---
const tools = [
  {
    letter: "A",
    title: "Academy",
    desc: "Avalanche Academy is a suite of courses for developers of all experience levels to hone their skills, while the Codebase Entrepreneur Academy offers the foundational knowledge needed to launch and grow your Web3 startup on Avalanche.",
    href: "https://build.avax.network/academy"
  },
  {
    letter: "B",
    title: "Builder Console",
    desc: "Manage your Avalanche L1s, validators, and deployments from one central location.",
    href: "https://build.avax.network/console"
  },
  {
    letter: "D",
    title: "Documentation",
    desc: "Get the full-stack of Avalanche documentation, all in one place.",
    href: "https://build.avax.network/docs"
  },
  {
    letter: "I",
    title: "Integrations",
    desc: "Discover best-in-class integrations for your Avalanche project and learn how to implement them.",
    href: "https://build.avax.network/integrations"
  },
  {
    letter: "T",
    title: "Tools",
    desc: "Find everything you need to launch, test, and manage Avalanche L1s and dApps—from faucet access to full deployment tools.",
    href: "https://build.avax.network/tools"
  }
];
---

<section class="build-section section">
  <div class="container">
    <div class="build-header" data-reveal>
      <h2 class="build-title">Build on the Network Designed for Big Ideas</h2>
    </div>

    <div class="build-content">
      <div class="build-desc" data-reveal>
        <p>Avalanche is the platform for developers looking to build, launch and scale without sacrificing speed, flexibility, or control. Start today and explore Avalanche's full-stack of developer tools and resources.</p>
      </div>

      <div class="build-tools">
        {tools.map((tool, i) => (
          <a href={tool.href} class="tool-card" target="_blank" rel="noopener" data-reveal data-reveal-delay={String(i + 1)}>
            <div class="tool-letter-wrap">
              <div class="tool-letter">{tool.letter}</div>
            </div>
            <div class="tool-info">
              <div class="tool-text">
                <h4 class="tool-title">{tool.title}</h4>
                <p class="tool-desc">{tool.desc}</p>
              </div>
              <button class="tool-btn">Learn More →</button>
            </div>
          </a>
        ))}

        <!-- Learn More CTA -->
        <div class="build-cta" data-reveal>
          <h3>Learn More About Building on Avalanche</h3>
          <a href="https://build.avax.network" target="_blank" rel="noopener" class="cta-btn">
            Start Building
            <span>→</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .build-section {
    background: var(--color-dark);
    padding: var(--padding-3xl) 0;
  }

  .build-header {
    margin-bottom: var(--gap-2xl);
  }

  .build-title {
    font-size: var(--text-7xl);
    font-weight: 400;
    text-transform: uppercase;
    color: var(--color-white);
    line-height: var(--leading-normal);
    max-width: 900px;
  }

  .build-content {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--gap-3xl);
    align-items: start;
  }

  .build-desc p {
    font-size: var(--text-xl);
    color: var(--color-neutral-400);
    line-height: 1.6;
  }

  .build-tools {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .tool-card {
    display: flex;
    align-items: stretch;
    background: #080808;
    border: 1px solid rgba(255,255,255,0.06);
    transition: background 0.3s ease, border-color 0.3s ease;
    overflow: hidden;
    position: relative;
    clip-path: polygon(
      0% 0%,
      100% 0%,
      100% calc(100% - 16px),
      calc(100% - 16px) 100%,
      0% 100%
    );
  }

  .tool-card:hover {
    background: #0e0e0e;
    border-color: rgba(255,255,255,0.1);
  }

  .tool-card::after {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--color-red);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .tool-card:hover::after {
    opacity: 1;
  }

  .tool-letter-wrap {
    flex-shrink: 0;
    width: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-right: 1px solid rgba(255,255,255,0.06);
    background: rgba(255,255,255,0.01);
    padding: var(--padding-md);
  }

  .tool-letter {
    font-size: var(--text-5xl);
    font-weight: 400;
    color: rgba(255,255,255,0.1);
    text-transform: uppercase;
    transition: color 0.3s ease;
  }

  .tool-card:hover .tool-letter {
    color: var(--color-red);
  }

  .tool-info {
    flex: 1;
    padding: var(--padding-md);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .tool-title {
    font-size: var(--text-2xl);
    font-weight: 600;
    color: var(--color-white);
    text-transform: uppercase;
    letter-spacing: -0.01em;
    margin-bottom: 0.5rem;
  }

  .tool-desc {
    font-size: var(--text-sm);
    color: var(--color-neutral-500);
    line-height: 1.5;
    max-width: 50ch;
  }

  .tool-btn {
    flex-shrink: 0;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-neutral-400);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    padding: 0.5rem 1rem;
    border: 1px solid rgba(255,255,255,0.1);
    transition: color 0.2s ease, border-color 0.2s ease;
    background: none;
  }

  .tool-card:hover .tool-btn {
    color: var(--color-white);
    border-color: rgba(255,255,255,0.2);
  }

  .build-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--padding-xl);
    background: #0a0302;
    border: 1px solid rgba(255,57,74,0.15);
    clip-path: polygon(
      0% 0%,
      100% 0%,
      100% calc(100% - 16px),
      calc(100% - 16px) 100%,
      0% 100%
    );
    gap: 2rem;
  }

  .build-cta h3 {
    font-size: var(--text-2xl);
    font-weight: 400;
    text-transform: uppercase;
    color: var(--color-white);
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2rem;
    background: var(--color-red);
    color: var(--color-white);
    font-size: var(--text-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: background 0.2s ease, gap 0.2s ease;
    flex-shrink: 0;
    clip-path: polygon(
      0% 0%,
      100% 0%,
      100% calc(100% - 10px),
      calc(100% - 10px) 100%,
      0% 100%
    );
  }

  .cta-btn:hover {
    background: #d42030;
    gap: 1rem;
  }

  @media (max-width: 1024px) {
    .build-content {
      grid-template-columns: 1fr;
      gap: var(--gap-xl);
    }

    .tool-info {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }

    .build-cta {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media (max-width: 768px) {
    .tool-letter-wrap {
      width: 60px;
    }
  }
</style>
