---
const solutions = [
  {
    letter: "I",
    title: "Institutions and Capital Markets",
    desc: "Avalanche's customizable, high-performance network helps bring traditional finance onchain.",
    href: "/institutions",
    color: "#2446a2"
  },
  {
    letter: "G",
    title: "Gaming",
    desc: "High-performance, immersive Web3 gaming powered by Avalanche's speed and scale.",
    href: "/gaming",
    color: "#0d3a0d"
  },
  {
    letter: "E",
    title: "Enterprise and Consumer Apps",
    desc: "Scalable solutions with real-world utility, from logistics to loyalty programs.",
    href: "/enterprise",
    color: "#1e1e2a"
  },
  {
    letter: "D",
    title: "Decentralized Finance (DeFi)",
    desc: "Fast, low-cost DeFi programs powering the future of financial systems.",
    href: "/defi",
    color: "#1a0a02"
  },
  {
    letter: "N",
    title: "NFTs, Arts, and Culture",
    desc: "The Avalanche network enables community building and connection for creatives.",
    href: "/nft",
    color: "#1a0202"
  },
  {
    letter: "I",
    title: "Infrastructure and Tooling",
    desc: "Developers can leverage a seamless network infrastructure and powerful tools designed to make building easy.",
    href: "/infrastructure",
    color: "#0a0a0a"
  }
];
---

<section class="solutions-section section">
  <div class="container">
    <div class="solutions-header" data-reveal>
      <h2 class="solutions-title">Avalanche Solutions</h2>
    </div>

    <div class="solutions-content">
      <div class="solutions-desc" data-reveal>
        <p>Avalanche empowers founders, businesses and institutions across industries, both Web2 and crypto-native, to build anything they want, any way they want. Take control with the best custom scaling solutions and supportive developer community on Avalanche.</p>
      </div>

      <div class="solutions-grid">
        {solutions.map((s, i) => (
          <a href={s.href} class="solution-card" data-reveal data-reveal-delay={String(i % 3 + 1)} style={`--sol-color: ${s.color}`}>
            <div class="sol-letter-wrap">
              <div class="sol-letter">{s.letter}</div>
            </div>
            <div class="sol-body">
              <h4 class="sol-title">{s.title}</h4>
              <p class="sol-desc">{s.desc}</p>
              <button class="sol-btn">View Details →</button>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .solutions-section {
    background: #030303;
    padding: var(--padding-3xl) 0;
  }

  .solutions-header {
    margin-bottom: var(--gap-2xl);
  }

  .solutions-title {
    font-size: var(--text-7xl);
    font-weight: 400;
    text-transform: uppercase;
    color: var(--color-white);
    line-height: var(--leading-normal);
  }

  .solutions-content {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--gap-3xl);
    align-items: start;
  }

  .solutions-desc p {
    font-size: var(--text-xl);
    color: var(--color-neutral-400);
    line-height: 1.6;
  }

  .solutions-grid {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .solution-card {
    display: flex;
    align-items: stretch;
    background: #080808;
    border: 1px solid rgba(255,255,255,0.06);
    overflow: hidden;
    transition: background 0.3s ease, border-color 0.3s ease;
    position: relative;
    clip-path: polygon(
      0% 0%,
      100% 0%,
      100% calc(100% - 16px),
      calc(100% - 16px) 100%,
      0% 100%
    );
  }

  .solution-card:hover {
    background: #0d0d0d;
    border-color: rgba(255,255,255,0.1);
  }

  .solution-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--sol-color, transparent);
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 0;
  }

  .solution-card:hover::before {
    opacity: 0.05;
  }

  .sol-letter-wrap {
    width: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-right: 1px solid rgba(255,255,255,0.06);
    background: rgba(255,255,255,0.01);
    position: relative;
    z-index: 1;
  }

  .sol-letter {
    font-size: var(--text-5xl);
    font-weight: 400;
    color: rgba(255,255,255,0.08);
    text-transform: uppercase;
    transition: color 0.3s ease;
  }

  .solution-card:hover .sol-letter {
    color: rgba(255,255,255,0.3);
  }

  .sol-body {
    flex: 1;
    padding: var(--padding-md);
    display: flex;
    align-items: center;
    gap: 2rem;
    position: relative;
    z-index: 1;
  }

  .sol-title {
    font-size: var(--text-xl);
    font-weight: 600;
    text-transform: uppercase;
    color: var(--color-white);
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
  }

  .sol-desc {
    font-size: var(--text-sm);
    color: var(--color-neutral-500);
    line-height: 1.5;
    max-width: 40ch;
    flex: 1;
  }

  .sol-btn {
    flex-shrink: 0;
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-neutral-400);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    padding: 0.5rem 1rem;
    border: 1px solid rgba(255,255,255,0.1);
    transition: all 0.2s ease;
    background: none;
  }

  .solution-card:hover .sol-btn {
    color: var(--color-white);
    border-color: rgba(255,255,255,0.25);
  }

  @media (max-width: 1024px) {
    .solutions-content {
      grid-template-columns: 1fr;
      gap: var(--gap-xl);
    }

    .sol-body {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
  }

  @media (max-width: 768px) {
    .sol-letter-wrap {
      width: 50px;
    }
  }
</style>
