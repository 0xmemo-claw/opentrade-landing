---
---

<section class="email-section section">
  <div class="container">
    <div class="email-content" data-reveal>
      <div class="email-bg">
        <!-- Background visual element -->
        <div class="email-visual">
          <div class="email-triangles">
            <div class="tri tri-1"></div>
            <div class="tri tri-2"></div>
            <div class="tri tri-3"></div>
          </div>
          <div class="email-text-bg">
            <span>START</span>
            <span>BUILDING ON</span>
            <span class="text-outline">AVALANCHE</span>
          </div>
        </div>
        <div class="email-overlay"></div>
      </div>

      <div class="email-form-area">
        <h2 class="email-title">Join the Email List</h2>
        <p class="email-desc">
          Join The Snow Report, Avalanche's newsletter featuring the latest network news, community spotlights, events and more.
        </p>
        <form class="email-form" id="email-form">
          <div class="input-group">
            <div class="input-wrapper">
              <input 
                type="email" 
                name="email"
                placeholder="Email Address"
                required
                class="email-input"
                autocomplete="email"
              />
              <label for="email">Email Address</label>
            </div>
            <button type="submit" class="email-submit">
              Subscribe
              <span class="submit-arrow">→</span>
            </button>
          </div>
          <p class="privacy-note">
            By submitting your email you agree to Avalanche's <a href="/privacy-policy">Privacy Policy</a> and <a href="/terms-of-use">Terms of Use</a>.
          </p>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .email-section {
    padding: var(--padding-3xl) 0;
    background: #050505;
  }

  .email-content {
    position: relative;
    overflow: hidden;
    min-height: 400px;
    display: flex;
    align-items: stretch;
    clip-path: polygon(
      0% 0%,
      100% 0%,
      100% calc(100% - 40px),
      calc(100% - 40px) 100%,
      0% 100%
    );
  }

  .email-bg {
    position: absolute;
    inset: 0;
  }

  .email-visual {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .email-triangles {
    position: absolute;
    inset: 0;
  }

  .tri {
    position: absolute;
    clip-path: polygon(50% 0%, 0% 100%, 100% 100%);
  }

  .tri-1 {
    width: 300px;
    height: 260px;
    top: -60px;
    left: 5%;
    background: linear-gradient(135deg, #FF394A, #8b0000);
    opacity: 0.8;
  }

  .tri-2 {
    width: 200px;
    height: 170px;
    top: 40px;
    left: 25%;
    background: linear-gradient(135deg, #1a0202, #FF394A);
    opacity: 0.5;
  }

  .tri-3 {
    width: 400px;
    height: 350px;
    top: -80px;
    right: 10%;
    background: linear-gradient(135deg, #0a0a0a, #FF394A);
    opacity: 0.15;
  }

  .email-text-bg {
    position: absolute;
    bottom: 1rem;
    left: var(--padding-xl);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .email-text-bg span {
    font-size: var(--text-5xl);
    font-weight: 400;
    text-transform: uppercase;
    color: rgba(255,255,255,0.9);
    line-height: var(--leading-normal);
    display: block;
  }

  .text-outline {
    -webkit-text-stroke: 1px rgba(255,255,255,0.3);
    color: transparent !important;
  }

  .email-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent 30%, rgba(0,0,0,0.9) 70%);
  }

  .email-form-area {
    position: relative;
    z-index: 2;
    margin-left: auto;
    width: 50%;
    padding: var(--padding-2xl);
    background: rgba(0,0,0,0.6);
    backdrop-filter: blur(10px);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.5rem;
  }

  .email-title {
    font-size: var(--text-5xl);
    font-weight: 400;
    text-transform: uppercase;
    color: var(--color-white);
    line-height: var(--leading-normal);
  }

  .email-desc {
    font-size: var(--text-base);
    color: var(--color-neutral-400);
    line-height: 1.6;
  }

  .input-group {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .input-wrapper {
    position: relative;
  }

  .email-input {
    width: 100%;
    height: 60px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.15);
    color: var(--color-white);
    font-family: var(--font-primary);
    font-size: var(--text-base);
    padding: 1.5rem 1.25rem 0.5rem;
    transition: border-color 0.3s ease;
    outline: none;
    appearance: none;
    -webkit-appearance: none;
  }

  .email-input::placeholder {
    color: transparent;
  }

  .input-wrapper label {
    position: absolute;
    top: 50%;
    left: 1.25rem;
    transform: translateY(-50%);
    font-size: var(--text-base);
    color: var(--color-neutral-500);
    pointer-events: none;
    transition: all 0.2s ease;
  }

  .email-input:focus ~ label,
  .email-input:not(:placeholder-shown) ~ label {
    top: 0.75rem;
    transform: translateY(0);
    font-size: var(--text-xs);
    color: var(--color-neutral-300);
  }

  .email-input:focus {
    border-color: rgba(255,255,255,0.3);
  }

  .email-submit {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    height: 56px;
    padding: 0 1.5rem;
    background: var(--color-red);
    color: var(--color-white);
    font-family: var(--font-primary);
    font-size: var(--text-base);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: background 0.2s ease;
    border: none;
    clip-path: polygon(
      0% 0%,
      100% 0%,
      100% calc(100% - 10px),
      calc(100% - 10px) 100%,
      0% 100%
    );
  }

  .email-submit:hover {
    background: #d42030;
  }

  .submit-arrow {
    font-size: 1.2em;
    transition: transform 0.2s ease;
  }

  .email-submit:hover .submit-arrow {
    transform: translateX(4px);
  }

  .privacy-note {
    font-size: var(--text-xs);
    color: var(--color-neutral-600);
    line-height: 1.5;
  }

  .privacy-note a {
    color: var(--color-neutral-400);
    text-decoration: underline;
    text-decoration-color: rgba(255,255,255,0.2);
    transition: color 0.2s ease;
  }

  .privacy-note a:hover {
    color: var(--color-white);
  }

  @media (max-width: 1024px) {
    .email-overlay {
      background: linear-gradient(180deg, transparent 0%, rgba(0,0,0,0.9) 60%);
    }

    .email-form-area {
      width: 100%;
      margin-left: 0;
      background: rgba(0,0,0,0.85);
      padding: var(--padding-xl);
    }

    .email-content {
      flex-direction: column;
    }
  }
</style>

<script>
  const form = document.getElementById('email-form') as HTMLFormElement;
  
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const emailInput = form.querySelector('input[type="email"]') as HTMLInputElement;
    if (emailInput?.value) {
      // Show success state
      const btn = form.querySelector('.email-submit') as HTMLButtonElement;
      if (btn) {
        btn.textContent = '✓ Subscribed!';
        btn.style.background = '#4ade80';
        btn.style.color = '#000';
        btn.disabled = true;
      }
    }
  });
</script>
