---
---

<section class="stats-section section">
  <div class="container">
    <div class="stats-header" data-reveal>
      <h2 class="stats-title">
        <span>Avalanche</span>
        <span class="title-outline">Network</span>
        <span>In Action</span>
      </h2>
      <h3 class="stats-subtitle">Explore the latest transactions and block data from the network.</h3>
    </div>

    <div class="stats-body">
      <!-- Total transactions counter -->
      <div class="stats-counter-block" data-reveal>
        <div class="stats-counter">
          <h3 class="counter-number" id="tx-count">13,277,353,281</h3>
          <div class="counter-label">
            <div class="live-indicator">
              <div class="live-dot"></div>
              <span>Live Stats</span>
            </div>
          </div>
        </div>
        <h4 class="counter-title">Transactions</h4>
      </div>

      <!-- Blocks & Transactions tables -->
      <div class="stats-tables" data-reveal>
        <div class="stats-table-col">
          <h3 class="table-title">Latest blocks</h3>
          <div class="blocks-list" id="blocks-list">
            {Array.from({length: 7}, (_, i) => (
              <div class="block-row">
                <div class="block-avatar">
                  <div class="avatar-circle">
                    <svg viewBox="0 0 32 32" fill="none">
                      <polygon points="16,3 29,25 3,25" fill="#FF394A" opacity="0.8"/>
                    </svg>
                  </div>
                </div>
                <div class="block-info">
                  <div class="block-name">Block {(12300000 + i * 1500000).toLocaleString()}</div>
                  <div class="block-meta">
                    <span class="meta-label">Hash</span>
                    <span class="meta-value">0x{Math.random().toString(16).slice(2, 6)}...{Math.random().toString(16).slice(2, 6)}</span>
                    <span class="meta-tx">{Math.floor(Math.random() * 30 + 1)} TX</span>
                  </div>
                </div>
                <div class="block-fee">&lt;0.01 AVAX</div>
              </div>
            ))}
          </div>
        </div>

        <div class="stats-table-col">
          <h3 class="table-title">Latest transactions</h3>
          <div class="txs-list" id="txs-list">
            {Array.from({length: 7}, (_, i) => (
              <div class="tx-row">
                <div class="tx-avatar">
                  <div class="avatar-circle">
                    <svg viewBox="0 0 32 32" fill="none">
                      <circle cx="16" cy="16" r="10" fill="#2446a2" opacity="0.6"/>
                      <circle cx="16" cy="16" r="5" fill="#2446a2"/>
                    </svg>
                  </div>
                </div>
                <div class="tx-info">
                  <div class="tx-hash">Hash 0x{Math.random().toString(16).slice(2, 6)}...{Math.random().toString(16).slice(2, 6)}</div>
                  <div class="tx-meta">
                    <span class="meta-label">From</span>
                    <span class="meta-value">0x{Math.random().toString(16).slice(2, 8)}...{Math.random().toString(16).slice(2, 6)}</span>
                    <span class="meta-label">To</span>
                    <span class="meta-value">0x{Math.random().toString(16).slice(2, 8)}...{Math.random().toString(16).slice(2, 6)}</span>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .stats-section {
    background: #050505;
    padding: var(--padding-3xl) 0;
    overflow: hidden;
  }

  .stats-header {
    margin-bottom: var(--gap-2xl);
  }

  .stats-title {
    font-size: var(--text-8xl);
    font-weight: 400;
    text-transform: uppercase;
    line-height: var(--leading-normal);
    margin-bottom: 1rem;
  }

  .stats-title span {
    display: block;
    color: var(--color-white);
  }

  .title-outline {
    -webkit-text-stroke: 1px rgba(255,255,255,0.3);
    color: transparent !important;
  }

  .stats-subtitle {
    font-size: var(--text-xl);
    color: var(--color-neutral-400);
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0;
  }

  .stats-body {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: var(--gap-xl);
    align-items: start;
  }

  /* Counter */
  .stats-counter-block {
    position: sticky;
    top: calc(var(--navbar-height) + 2rem);
  }

  .stats-counter {
    margin-bottom: 1rem;
  }

  .counter-number {
    font-size: var(--text-5xl);
    font-weight: 400;
    color: var(--color-white);
    letter-spacing: -0.02em;
    line-height: 1;
    margin-bottom: 0.75rem;
    font-variant-numeric: tabular-nums;
  }

  .live-indicator {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .live-dot {
    width: 8px;
    height: 8px;
    background: var(--color-red);
    border-radius: 50%;
    animation: livePulse 1.5s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes livePulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.8); }
  }

  .live-indicator span {
    font-size: var(--text-xs);
    color: var(--color-neutral-400);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
  }

  .counter-title {
    font-size: var(--text-2xl);
    font-weight: 400;
    text-transform: uppercase;
    color: var(--color-neutral-400);
  }

  /* Tables */
  .stats-tables {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--gap-md);
  }

  .table-title {
    font-size: var(--text-base);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-neutral-300);
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  /* Block rows */
  .block-row, .tx-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    transition: background 0.2s ease;
  }

  .block-row:hover, .tx-row:hover {
    background: rgba(255,255,255,0.02);
    padding-left: 0.5rem;
  }

  .avatar-circle {
    width: 32px;
    height: 32px;
    background: rgba(255,255,255,0.05);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    overflow: hidden;
  }

  .avatar-circle svg {
    width: 20px;
    height: 20px;
  }

  .block-info, .tx-info {
    flex: 1;
    min-width: 0;
  }

  .block-name, .tx-hash {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-white);
    margin-bottom: 0.25rem;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .block-meta, .tx-meta {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  .meta-label {
    font-size: var(--text-xs);
    color: var(--color-neutral-500);
    font-weight: 600;
  }

  .meta-value {
    font-size: var(--text-xs);
    color: var(--color-neutral-300);
    font-variant-numeric: tabular-nums;
  }

  .meta-tx {
    font-size: var(--text-xs);
    color: var(--color-neutral-400);
    padding: 0.15rem 0.4rem;
    background: rgba(255,255,255,0.04);
    border-radius: 4px;
  }

  .block-fee {
    font-size: var(--text-xs);
    color: var(--color-neutral-400);
    white-space: nowrap;
    flex-shrink: 0;
  }

  @media (max-width: 1200px) {
    .stats-body {
      grid-template-columns: 1fr;
    }

    .stats-counter-block {
      position: static;
    }
  }

  @media (max-width: 768px) {
    .stats-tables {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // Animate counter up
  function animateCounter(el: HTMLElement, target: number, duration: number = 2000) {
    const start = 0;
    const startTime = performance.now();
    
    const update = (currentTime: number) => {
      const elapsed = currentTime - startTime;
      const progress = Math.min(elapsed / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 4); // ease out quart
      const current = Math.round(start + (target - start) * eased);
      el.textContent = current.toLocaleString();
      
      if (progress < 1) {
        requestAnimationFrame(update);
      }
    };
    
    requestAnimationFrame(update);
  }

  const counterEl = document.getElementById('tx-count');
  if (counterEl) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          animateCounter(counterEl, 13277353281, 2500);
          observer.unobserve(counterEl);
        }
      });
    }, { threshold: 0.5 });
    
    observer.observe(counterEl);
  }
</script>
