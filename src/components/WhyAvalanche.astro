---
const features = [
  {
    num: "01",
    title: "Fast. Powerful. Secure.",
    desc: "The groundbreaking Avalanche consensus powers a network of fast, efficient, highly-optimized chains that finalize transactions almost instantly. Accompanied by a best-in-class developer experience and suite of tools, Avalanche is the platform of choice for builders and users ready for what's next in Web3.",
    color: "#FF394A",
    bg: "#1a0202"
  },
  {
    num: "02",
    title: "Infinitely Scalable by Design",
    desc: "Avalanche is where Web3's big ideas scale with confidence. Whether it's a single application, or launching a fully-customizable Layer 1 blockchain, Avalanche makes it easy to scale up — or across — in an interconnected ecosystem.",
    color: "#2446a2",
    bg: "#020a1a"
  },
  {
    num: "03",
    title: "Customizable Layer 1s",
    desc: "Whatever your use-case, Avalanche makes launching your own L1 more economically feasible, simpler to customize, smoother to maintain and quicker to bring to market. The network is anchored by a lightning-fast and efficient primary chain and a universe of sovereign blockchains, all natively connected through Avalanche Interchain Messaging.",
    color: "#1e1e2a",
    bg: "#0a0a0a"
  },
  {
    num: "04",
    title: "Global Community",
    desc: "Avalanche is more than just a blockchain network. It's a global community of builders, creators, and collaborators, all together on a mission to drive the adoption of blockchain technology. There are no gatekeepers, just an open ecosystem where knowledge and resources are shared, creating a global movement ready to turn ideas into real-world impact.",
    color: "#151413",
    bg: "#050505"
  }
];
---

<section class="why-section section">
  <div class="container">
    <div class="why-header" data-reveal>
      <h2 class="why-title">
        <span class="title-line">Why</span>
        <span class="title-line title-highlight">Avalanche</span>
      </h2>
    </div>

    <div class="why-items">
      {features.map((f, i) => (
        <div class="why-item" data-reveal style={`--item-bg: ${f.bg}; --item-accent: ${f.color}`}>
          <div class="why-item-inner">
            <div class="why-item-top">
              <div class="why-item-number-block">
                <div class="why-icon">
                  <svg viewBox="0 0 60 60" fill="none">
                    <polygon points="30,5 55,50 5,50" stroke={f.color} stroke-width="2" fill="none" opacity="0.5"/>
                    <polygon points="30,15 45,45 15,45" fill={f.color} opacity="0.2"/>
                  </svg>
                </div>
                <p class="why-num">{f.num}</p>
              </div>
              <div class="why-item-content">
                <div class="why-text">
                  <h2 class="why-item-title">{f.title}</h2>
                  <p class="why-item-desc">{f.desc}</p>
                </div>
              </div>
            </div>
            <!-- Symbol decoration -->
            <div class="why-symbol">
              <svg viewBox="0 0 100 100" fill="none">
                <polygon points="50,5 95,95 5,95" stroke={f.color} stroke-width="1.5" fill="none"/>
                <polygon points="50,25 75,75 25,75" fill={f.color} opacity="0.15"/>
              </svg>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .why-section {
    background: var(--color-neutral-950);
    padding-top: var(--padding-3xl);
    padding-bottom: var(--padding-3xl);
  }

  .why-header {
    margin-bottom: var(--gap-2xl);
  }

  .why-title {
    font-size: var(--text-8xl);
    line-height: var(--leading-normal);
    font-weight: 400;
    text-transform: uppercase;
  }

  .title-line {
    display: block;
    color: rgba(255,255,255,0.3);
  }

  .title-highlight {
    color: var(--color-white);
  }

  .why-items {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .why-item {
    background: var(--item-bg, #0a0a0a);
    border: 1px solid rgba(255,255,255,0.05);
    position: relative;
    overflow: hidden;
    clip-path: polygon(
      0% 0%,
      100% 0%,
      100% calc(100% - 30px),
      calc(100% - 30px) 100%,
      0% 100%
    );
    transition: background 0.3s ease;
  }

  .why-item:hover {
    border-color: rgba(255,255,255,0.1);
  }

  .why-item-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--padding-xl) var(--padding-2xl);
    position: relative;
    z-index: 2;
    gap: var(--gap-xl);
  }

  .why-item-top {
    display: flex;
    align-items: flex-start;
    gap: var(--gap-xl);
    flex: 1;
  }

  .why-item-number-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
    width: clamp(3rem, 5vw, 5rem);
  }

  .why-icon {
    width: clamp(2.5rem, 4vw, 4rem);
    height: clamp(2.5rem, 4vw, 4rem);
  }

  .why-icon svg {
    width: 100%;
    height: 100%;
  }

  .why-num {
    font-size: var(--text-xs);
    color: var(--color-neutral-400);
    font-weight: 600;
    letter-spacing: 0.1em;
  }

  .why-item-content {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--gap-xl);
  }

  .why-text {
    max-width: 700px;
  }

  .why-item-title {
    font-size: var(--text-5xl);
    font-weight: 400;
    text-transform: uppercase;
    color: var(--color-white);
    margin-bottom: 1rem;
    line-height: var(--leading-normal);
  }

  .why-item-desc {
    font-size: var(--text-base);
    color: var(--color-neutral-400);
    line-height: 1.6;
    max-width: 60ch;
  }

  .why-symbol {
    width: clamp(4rem, 7vw, 7rem);
    height: clamp(4rem, 7vw, 7rem);
    flex-shrink: 0;
    opacity: 0.4;
    transition: opacity 0.3s ease;
  }

  .why-symbol svg {
    width: 100%;
    height: 100%;
  }

  .why-item:hover .why-symbol {
    opacity: 0.7;
  }

  /* Item accent glow */
  .why-item::before {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 40%;
    height: 100%;
    background: radial-gradient(ellipse at 80% 50%, var(--item-accent, transparent) 0%, transparent 70%);
    opacity: 0.08;
    pointer-events: none;
  }

  @media (max-width: 1024px) {
    .why-item-inner {
      padding: var(--padding-xl);
    }

    .why-item-top {
      flex-direction: column;
      gap: 1rem;
    }

    .why-item-number-block {
      flex-direction: row;
      width: auto;
    }

    .why-symbol {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .why-item-inner {
      flex-direction: column;
      padding: 1.5rem;
    }

    .why-item-title {
      font-size: var(--text-4xl);
    }
  }
</style>

<script>
  import gsap from 'gsap';
  
  // Stagger the why items on scroll
  const items = document.querySelectorAll('.why-item');
  
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const el = entry.target as HTMLElement;
        const idx = Array.from(items).indexOf(el);
        gsap.from(el, {
          x: -50,
          opacity: 0,
          duration: 0.8,
          delay: idx * 0.1,
          ease: 'power3.out'
        });
        observer.unobserve(el);
      }
    });
  }, { threshold: 0.2 });
  
  items.forEach(item => observer.observe(item));
</script>
