---
const socials = [
  { name: 'X', href: 'https://x.com/avax', icon: 'X' },
  { name: 'Arena', href: 'https://arena.social/avax', icon: 'A' },
  { name: 'Discord', href: 'https://discord.gg/avax', icon: 'D' },
  { name: 'YouTube', href: 'https://www.youtube.com/Avalancheavax', icon: 'YT' },
  { name: 'Reddit', href: 'https://www.reddit.com/r/Avax/', icon: 'R' },
  { name: 'LinkedIn', href: 'https://www.linkedin.com/company/avalancheavax/', icon: 'Li' },
];

const tweets = [
  {
    user: "Avalanche🔺",
    handle: "avax",
    text: "Another AVAX ETF is now tradable on @Nasdaq. Introducing $GAVA from @Grayscale.",
    href: "#"
  },
  {
    user: "Future of Gaming",
    handle: "FutureofGaming",
    text: "I still do wdym",
    href: "#"
  },
  {
    user: "Avalanche🔺",
    handle: "avax",
    text: "Introducing Team1 USA. Team1, Avalanche's largest community organization, is now officially expanding into the US. @Team1USA_ is bringing frequent Avalanche events to cities across the US. Community building is building🔺",
    href: "#"
  },
  {
    user: "Avalanche Foundation 🔺",
    handle: "AvalancheFDN",
    text: "The Retro9000 C-Chain Round is now live 🔺 This round supports builders with retroactive grants for generating real activity on the Avalanche C-Chain from the $40M funding pool. Build. Burn. Earn.",
    href: "#"
  },
  {
    user: "Avalanche Foundation 🔺",
    handle: "AvalancheFDN",
    text: "Retro9000: C-Chain Round is heating up 🔺 The first round launches March 2, 2026 - rewarding projects driving real onchain activity on Avalanche with incentives from the $40M funding pool. Build. Burn. Earn.",
    href: "#"
  },
  {
    user: "Avalanche Community",
    handle: "AllAvax",
    text: "New Community Bounties are live with @AvaxTeam1🔺 Earn while supporting the Avalanche ecosystem 👇",
    href: "#"
  },
];
---

<section class="community-section section">
  <div class="container">
    <div class="community-header" data-reveal>
      <h2 class="community-title">Join The Best Community in web3</h2>
      <p class="community-desc">
        The Avalanche culture goes beyond the chain. Get connected with the founders, investors, artists, gamers, and creators who call Avalanche home.
      </p>
    </div>

    <!-- Social links bar -->
    <div class="social-bar" data-reveal>
      {socials.map(s => (
        <a href={s.href} class="social-pill" target="_blank" rel="noopener">
          <span class="social-icon">{s.icon}</span>
          <span class="social-name">{s.name}</span>
        </a>
      ))}
    </div>

    <!-- Tweet feed -->
    <div class="tweet-feed-wrapper" data-reveal>
      <div class="tweet-feed" id="tweet-feed">
        {tweets.map(t => (
          <a href={t.href} class="tweet-card" target="_blank" rel="noopener">
            <div class="tweet-header">
              <div class="tweet-avatar">
                {t.handle[0].toUpperCase()}
              </div>
              <div class="tweet-user">
                <span class="tweet-name">{t.user}</span>
                <span class="tweet-handle">@{t.handle}</span>
              </div>
              <div class="tweet-x">
                <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.748l7.73-8.835L1.254 2.25H8.08l4.253 5.622 5.91-5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
              </div>
            </div>
            <p class="tweet-text">{t.text}</p>
          </a>
        ))}
      </div>
      <div class="tweet-actions">
        <a href="https://x.com/avax" target="_blank" rel="noopener" class="follow-btn">
          Follow @avax
          <span>→</span>
        </a>
        <div class="feed-nav">
          <button class="page-btn" id="prev-tweets" disabled>
            <svg viewBox="0 0 24 24" fill="none" width="18" height="18">
              <path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </button>
          <button class="page-btn" id="next-tweets">
            <svg viewBox="0 0 24 24" fill="none" width="18" height="18">
              <path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .community-section {
    background: var(--color-dark);
    padding: var(--padding-3xl) 0;
    overflow: hidden;
  }

  .community-header {
    margin-bottom: var(--gap-2xl);
    max-width: 700px;
  }

  .community-title {
    font-size: var(--text-7xl);
    font-weight: 400;
    text-transform: uppercase;
    color: var(--color-white);
    margin-bottom: 1.5rem;
    line-height: var(--leading-normal);
  }

  .community-desc {
    font-size: var(--text-xl);
    color: var(--color-neutral-400);
    line-height: 1.6;
  }

  /* Social bar */
  .social-bar {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: var(--gap-2xl);
  }

  .social-pill {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    border: 1px solid rgba(255,255,255,0.1);
    background: rgba(255,255,255,0.02);
    transition: background 0.2s ease, border-color 0.2s ease;
    clip-path: polygon(
      0% 0%,
      calc(100% - 8px) 0%,
      100% 8px,
      100% 100%,
      0% 100%
    );
  }

  .social-pill:hover {
    background: rgba(255,255,255,0.05);
    border-color: rgba(255,255,255,0.2);
  }

  .social-icon {
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-neutral-300);
    min-width: 1.5rem;
    text-align: center;
  }

  .social-name {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-neutral-300);
  }

  /* Tweet feed */
  .tweet-feed-wrapper {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .tweet-feed {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .tweet-card {
    background: #080808;
    border: 1px solid rgba(255,255,255,0.06);
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: background 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
    clip-path: polygon(
      0% 0%,
      100% 0%,
      100% calc(100% - 12px),
      calc(100% - 12px) 100%,
      0% 100%
    );
  }

  .tweet-card:hover {
    background: #0e0e0e;
    border-color: rgba(255,255,255,0.1);
    transform: translateY(-2px);
  }

  .tweet-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .tweet-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--color-red);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-sm);
    font-weight: 700;
    color: white;
    flex-shrink: 0;
  }

  .tweet-user {
    flex: 1;
    min-width: 0;
  }

  .tweet-name {
    display: block;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-white);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .tweet-handle {
    display: block;
    font-size: var(--text-xs);
    color: var(--color-neutral-500);
  }

  .tweet-x {
    color: var(--color-neutral-500);
    flex-shrink: 0;
  }

  .tweet-text {
    font-size: var(--text-sm);
    color: var(--color-neutral-300);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  .tweet-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .follow-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background: var(--color-red);
    color: var(--color-white);
    font-size: var(--text-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: background 0.2s ease, gap 0.2s ease;
    clip-path: polygon(
      0% 0%,
      100% 0%,
      100% calc(100% - 8px),
      calc(100% - 8px) 100%,
      0% 100%
    );
  }

  .follow-btn:hover {
    background: #d42030;
    gap: 0.75rem;
  }

  .feed-nav {
    display: flex;
    gap: 0.5rem;
  }

  .page-btn {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255,255,255,0.15);
    background: none;
    color: var(--color-white);
    cursor: pointer;
    transition: background 0.2s ease;
  }

  .page-btn:hover:not([disabled]) {
    background: rgba(255,255,255,0.05);
  }

  .page-btn[disabled] {
    opacity: 0.3;
    cursor: default;
  }

  @media (max-width: 1200px) {
    .tweet-feed {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 900px) {
    .tweet-feed {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .tweet-feed {
      grid-template-columns: 1fr;
    }
  }
</style>
