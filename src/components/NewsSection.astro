<section class="news-section section">
  <div class="container">
    <div class="news-header" data-reveal>
      <div class="news-title-row">
        <h2 class="news-title">News &amp; Stories from the Avalanche Network</h2>
      </div>

      <div class="news-nav">
        <h3>News</h3>
        <div class="news-pagination">
          <button class="page-btn prev" id="prev-news" disabled aria-label="Previous">
            <svg viewBox="0 0 24 24" fill="none">
              <path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </button>
          <button class="page-btn next" id="next-news" aria-label="Next">
            <svg viewBox="0 0 24 24" fill="none">
              <path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <div class="news-grid" id="news-grid">
      {articles.map((a, i) => (
        <a href={a.href} class="news-card" data-reveal data-reveal-delay={String((i % 3) + 1)} style={`--card-bg: ${a.color}10;`}>
          <div class="news-card-image" style={`background: linear-gradient(135deg, ${a.color}40 0%, #0a0a0a 100%)`}>
            <div class="news-image-placeholder">
              <div class="news-triangle" style={`border-bottom-color: ${a.color}`}></div>
            </div>
          </div>
          <div class="news-card-body">
            <div class="news-tags">
              {a.tag && <span class="tag tag-primary">{a.tag}</span>}
              {a.type && <span class="tag tag-type">{a.type}</span>}
            </div>
            <p class="news-meta">{a.date} / By {a.author} / {a.readTime}</p>
            <h4 class="news-card-title">{a.title}</h4>
            <p class="news-card-desc">{a.desc}</p>
            <button class="news-read-btn">Read More →</button>
          </div>
        </a>
      ))}
    </div>

    <div class="news-footer" data-reveal>
      <a href="/about/blog" class="view-more-btn">
        View More
        <span>→</span>
      </a>
    </div>
  </div>
</section>

<style>
  .news-section {
    background: var(--color-dark);
    padding: var(--padding-3xl) 0;
  }

  .news-header {
    margin-bottom: var(--gap-2xl);
  }

  .news-title-row {
    margin-bottom: 1.5rem;
  }

  .news-title {
    font-size: var(--text-6xl);
    font-weight: 400;
    text-transform: uppercase;
    color: var(--color-white);
    line-height: var(--leading-normal);
    max-width: 800px;
  }

  .news-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid rgba(255,255,255,0.08);
    padding-top: 1.5rem;
  }

  .news-nav h3 {
    font-size: var(--text-2xl);
    font-weight: 400;
    text-transform: uppercase;
    color: var(--color-white);
  }

  .news-pagination {
    display: flex;
    gap: 0.5rem;
  }

  .page-btn {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255,255,255,0.15);
    background: none;
    color: var(--color-white);
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .page-btn svg {
    width: 20px;
    height: 20px;
  }

  .page-btn:hover:not([disabled]) {
    background: rgba(255,255,255,0.05);
    border-color: rgba(255,255,255,0.3);
  }

  .page-btn[disabled] {
    opacity: 0.3;
    cursor: default;
  }

  /* Grid */
  .news-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    margin-bottom: var(--gap-xl);
  }

  .news-card {
    display: flex;
    flex-direction: column;
    background: #080808;
    border: 1px solid rgba(255,255,255,0.06);
    overflow: hidden;
    transition: border-color 0.3s ease, transform 0.3s var(--ease-out-cubic);
    clip-path: polygon(
      0% 0%,
      100% 0%,
      100% calc(100% - 20px),
      calc(100% - 20px) 100%,
      0% 100%
    );
  }

  .news-card:hover {
    border-color: rgba(255,255,255,0.12);
    transform: translateY(-4px);
  }

  .news-card-image {
    aspect-ratio: 16/9;
    position: relative;
    overflow: hidden;
  }

  .news-image-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.6;
  }

  .news-triangle {
    width: 0;
    height: 0;
    border-left: 40px solid transparent;
    border-right: 40px solid transparent;
    border-bottom: 70px solid var(--color-red);
  }

  .news-card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
  }

  .news-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.2rem 0.5rem;
  }

  .tag-primary {
    color: var(--color-red);
    border: 1px solid rgba(255,57,74,0.3);
  }

  .tag-type {
    color: var(--color-neutral-400);
    border: 1px solid rgba(255,255,255,0.1);
  }

  .news-meta {
    font-size: var(--text-xs);
    color: var(--color-neutral-500);
    letter-spacing: 0.02em;
  }

  .news-card-title {
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-white);
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1.3;
    flex: 1;
  }

  .news-card-desc {
    font-size: var(--text-sm);
    color: var(--color-neutral-500);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .news-read-btn {
    align-self: flex-start;
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-red);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.5rem 1rem;
    border: 1px solid rgba(255,57,74,0.3);
    background: none;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
    clip-path: polygon(
      0% 0%,
      100% 0%,
      100% calc(100% - 8px),
      calc(100% - 8px) 100%,
      0% 100%
    );
  }

  .news-card:hover .news-read-btn {
    background: var(--color-red);
    color: var(--color-white);
  }

  .news-footer {
    display: flex;
    justify-content: center;
  }

  .view-more-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2.5rem;
    border: 1px solid rgba(255,255,255,0.2);
    color: var(--color-white);
    font-size: var(--text-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: background 0.2s ease, border-color 0.2s ease, gap 0.2s ease;
    clip-path: polygon(
      0% 0%,
      100% 0%,
      100% calc(100% - 12px),
      calc(100% - 12px) 100%,
      0% 100%
    );
  }

  .view-more-btn:hover {
    background: rgba(255,255,255,0.05);
    border-color: rgba(255,255,255,0.4);
    gap: 1rem;
  }

  @media (max-width: 1200px) {
    .news-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .news-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
