---
const cards = [
  {
    icon: '💎',
    title: 'Set up a wallet',
    desc: 'To connect to the Avalanche ecosystem, set up a non-custodial wallet to store your crypto assets, approve transactions, track your network activity and more.',
    btnText: 'Create a Wallet',
    href: 'https://core.app'
  },
  {
    icon: '🔺',
    title: 'The AVAX Token',
    desc: 'AVAX powers the Avalanche network—used for paying fees, securing the platform, and fueling custom blockchain operations.',
    btnText: 'Learn More',
    href: 'https://coinmarketcap.com/currencies/avalanche/'
  },
  {
    icon: '🌐',
    title: 'Explore the Ecosystem',
    desc: 'Discover the expanding web of applications, tools and experiences across the Avalanche network.',
    btnText: 'Start Exploring',
    href: 'https://core.app/discover/'
  }
];
---

<section class="getstarted-section section" data-reveal>
  <div class="container">
    <div class="getstarted-grid">
      {cards.map((card, i) => (
        <div class="gs-card" data-reveal data-reveal-delay={String(i + 1)}>
          <div class="gs-card-inner">
            <div class="gs-icon">{card.icon}</div>
            <h2 class="gs-title">{card.title}</h2>
            <p class="gs-desc">{card.desc}</p>
            <div class="gs-footer">
              <a href={card.href} class="btn-link" target="_blank" rel="noopener">
                {card.btnText}
                <span class="btn-arrow">→</span>
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .getstarted-section {
    background: var(--color-dark);
    padding: var(--padding-3xl) 0;
  }

  .getstarted-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
  }

  .gs-card {
    position: relative;
    background: #0a0a0a;
    border: 1px solid rgba(255,255,255,0.06);
    overflow: hidden;
    transition: border-color 0.3s ease, background 0.3s ease;
    clip-path: polygon(
      0% 0%,
      100% 0%,
      100% calc(100% - 20px),
      calc(100% - 20px) 100%,
      0% 100%
    );
  }

  .gs-card:hover {
    border-color: rgba(255,255,255,0.12);
    background: #0f0f0f;
  }

  .gs-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--color-red);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .gs-card:hover::before {
    opacity: 1;
  }

  .gs-card-inner {
    padding: var(--padding-xl);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    height: 100%;
  }

  .gs-icon {
    font-size: 2.5rem;
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .gs-title {
    font-size: var(--text-4xl);
    font-weight: 400;
    text-transform: uppercase;
    color: var(--color-white);
    line-height: var(--leading-normal);
  }

  .gs-desc {
    font-size: var(--text-base);
    color: var(--color-neutral-400);
    line-height: 1.6;
    flex: 1;
  }

  .gs-footer {
    margin-top: auto;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .btn-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-white);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: gap 0.2s ease, color 0.2s ease;
  }

  .btn-arrow {
    color: var(--color-red);
    font-size: 1.1em;
    transition: transform 0.2s ease;
  }

  .btn-link:hover {
    gap: 0.75rem;
    color: var(--color-neutral-100);
  }

  .btn-link:hover .btn-arrow {
    transform: translateX(3px);
  }

  @media (max-width: 1024px) {
    .getstarted-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .getstarted-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
