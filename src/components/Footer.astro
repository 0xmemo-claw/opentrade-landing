---
const footerLinks = {
  "Build": [
    { label: "Developer Hub", href: "/build/developer-hub" },
    { label: "Validators", href: "/build/validators" },
    { label: "Documentation", href: "https://build.avax.network/docs" },
    { label: "Academy", href: "https://build.avax.network/academy" },
    { label: "Tools", href: "https://build.avax.network/tools" },
    { label: "Grants", href: "https://build.avax.network/grants" },
    { label: "Integrations", href: "https://build.avax.network/integrations" },
    { label: "Hackathons", href: "https://build.avax.network/hackathons" },
  ],
  "Solutions": [
    { label: "Institutions & Capital Markets", href: "/institutions" },
    { label: "Gaming", href: "/gaming" },
    { label: "Enterprise & Consumer Apps", href: "/enterprise" },
    { label: "Decentralized Finance (DeFi)", href: "/defi" },
    { label: "NFTs, Arts & Culture", href: "/nft" },
    { label: "Infrastructure and Tooling", href: "/infrastructure" },
  ],
  "Community": [
    { label: "Community Hub", href: "/community-hub" },
    { label: "Events", href: "/community-hub/events" },
    { label: "Snow Report Newsletter", href: "/community-hub/newsletter" },
    { label: "Discord Community", href: "https://discord.gg/avax" },
  ],
  "About": [
    { label: "About Avalanche", href: "/about" },
    { label: "Avalanche Foundation", href: "/about/foundation" },
    { label: "Blog", href: "/about/blog" },
    { label: "Contact Us", href: "/about/contact-us" },
    { label: "Press", href: "/about/press" },
  ],
};

const socials = [
  { name: "X", href: "https://x.com/avax" },
  { name: "Discord", href: "https://discord.gg/avax" },
  { name: "YouTube", href: "https://www.youtube.com/Avalancheavax" },
  { name: "Reddit", href: "https://www.reddit.com/r/Avax/" },
  { name: "LinkedIn", href: "https://www.linkedin.com/company/avalancheavax/" },
  { name: "GitHub", href: "https://github.com/ava-labs" },
];
---

<footer class="footer">
  <div class="footer-top">
    <div class="container">
      <div class="footer-cta" data-reveal>
        <div class="footer-cta-content">
          <h2 class="footer-cta-title">Start Building on Avalanche Today</h2>
        </div>
        <div class="footer-cta-actions">
          <a href="https://build.avax.network" target="_blank" rel="noopener" class="footer-cta-btn primary">
            Start Building
            <span>→</span>
          </a>
          <a href="/about/contact-us" class="footer-cta-btn secondary">
            Talk to an Expert
            <span>→</span>
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="footer-main">
    <div class="container">
      <div class="footer-grid">
        <!-- Brand column -->
        <div class="footer-brand">
          <a href="/" class="footer-logo">
            <svg width="120" height="28" viewBox="0 0 140 32" fill="none">
              <path d="M16 2L30 28H2L16 2Z" fill="#FF394A"/>
              <path d="M42 24L47.5 8h2.8L56 24h-3l-1.2-3.8h-5.6L45 24h-3zm5.4-6h4l-2-6.5-2 6.5zM58 8h3v13.5h7V24H58V8zM70 8h3v13.5h7V24H70V8zM83 8l4.5 12L92 8h3l-6 16h-3l-6-16h3zM99 8h10v2.5h-7v3.8h6.5v2.5H102v4.7h7.2V24H99V8zM113 16c0-4.8 3.2-8.3 8-8.3 3.2 0 5.5 1.4 6.7 3.6l-2.5 1.4c-.8-1.5-2.3-2.5-4.2-2.5-2.9 0-5 2.3-5 5.8s2.1 5.8 5 5.8c1.9 0 3.4-1 4.2-2.5l2.5 1.4c-1.2 2.2-3.5 3.6-6.7 3.6-4.8 0-8-3.5-8-8.3zM131 8h3v6.5l6-6.5h3.8l-6.5 7 6.8 9h-3.8l-5-6.8-1.3 1.4V24h-3V8z" fill="white"/>
            </svg>
          </a>
          <p class="footer-brand-desc">
            The fastest, most scalable, and most secure blockchain platform in the world.
          </p>
          <div class="footer-socials">
            {socials.map(s => (
              <a href={s.href} class="footer-social" target="_blank" rel="noopener" aria-label={s.name}>
                <span>{s.name.slice(0, 2)}</span>
              </a>
            ))}
          </div>
          <div class="footer-avax-token">
            <a href="/avax" class="avax-token-btn">
              <div class="avax-token-icon">
                <svg viewBox="0 0 32 32" fill="none" width="20" height="20">
                  <path d="M16 2L30 28H2L16 2Z" fill="#FF394A"/>
                </svg>
              </div>
              <div class="avax-token-info">
                <span class="avax-token-label">AVAX Token</span>
                <span class="avax-token-arrow">→</span>
              </div>
            </a>
          </div>
        </div>

        <!-- Link columns -->
        {Object.entries(footerLinks).map(([heading, links]) => (
          <div class="footer-col">
            <h3 class="footer-col-heading">{heading}</h3>
            <ul class="footer-col-links">
              {links.map(link => (
                <li>
                  <a href={link.href} class="footer-link">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container">
      <div class="footer-bottom-inner">
        <p class="footer-copyright">
          © {new Date().getFullYear()} Ava Labs. All rights reserved.
        </p>
        <div class="footer-legal-links">
          <a href="/privacy-policy">Privacy Policy</a>
          <a href="/terms-of-use">Terms of Use</a>
          <a href="/cookie-policy">Cookie Settings</a>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-dark);
    border-top: 1px solid rgba(255,255,255,0.05);
  }

  /* CTA Banner */
  .footer-top {
    background: var(--color-dark);
    border-bottom: 1px solid rgba(255,255,255,0.05);
    padding: var(--padding-2xl) 0;
  }

  .footer-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .footer-cta-title {
    font-size: var(--text-5xl);
    font-weight: 400;
    text-transform: uppercase;
    color: var(--color-white);
    line-height: var(--leading-normal);
  }

  .footer-cta-actions {
    display: flex;
    gap: 1rem;
    flex-shrink: 0;
  }

  .footer-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2rem;
    font-size: var(--text-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: all 0.2s ease;
    clip-path: polygon(
      0% 0%,
      100% 0%,
      100% calc(100% - 10px),
      calc(100% - 10px) 100%,
      0% 100%
    );
  }

  .footer-cta-btn.primary {
    background: var(--color-red);
    color: var(--color-white);
  }

  .footer-cta-btn.primary:hover {
    background: #d42030;
    gap: 1rem;
  }

  .footer-cta-btn.secondary {
    background: rgba(255,255,255,0.05);
    color: var(--color-white);
    border: 1px solid rgba(255,255,255,0.15);
  }

  .footer-cta-btn.secondary:hover {
    background: rgba(255,255,255,0.08);
    gap: 1rem;
  }

  /* Main footer */
  .footer-main {
    padding: var(--padding-2xl) 0;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr repeat(4, 1fr);
    gap: var(--gap-xl);
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .footer-logo svg {
    height: 28px;
    width: auto;
  }

  .footer-brand-desc {
    font-size: var(--text-sm);
    color: var(--color-neutral-500);
    line-height: 1.6;
    max-width: 280px;
  }

  .footer-socials {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .footer-social {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255,255,255,0.1);
    background: rgba(255,255,255,0.02);
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-neutral-400);
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }

  .footer-social:hover {
    background: rgba(255,255,255,0.06);
    color: var(--color-white);
    border-color: rgba(255,255,255,0.2);
  }

  .avax-token-btn {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    border: 1px solid rgba(255,255,255,0.1);
    background: rgba(255,255,255,0.02);
    transition: background 0.2s ease, border-color 0.2s ease;
    width: fit-content;
    clip-path: polygon(
      0% 0%,
      calc(100% - 8px) 0%,
      100% 8px,
      100% 100%,
      0% 100%
    );
  }

  .avax-token-btn:hover {
    background: rgba(255,255,255,0.05);
    border-color: rgba(255,255,255,0.2);
  }

  .avax-token-icon {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255,57,74,0.1);
    border-radius: 50%;
  }

  .avax-token-info {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .avax-token-label {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-white);
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .avax-token-arrow {
    color: var(--color-red);
  }

  /* Link columns */
  .footer-col-heading {
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-white);
    margin-bottom: 1.25rem;
  }

  .footer-col-links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-link {
    font-size: var(--text-sm);
    color: var(--color-neutral-500);
    text-transform: none;
    transition: color 0.2s ease, padding-left 0.2s ease;
    display: inline-block;
  }

  .footer-link:hover {
    color: var(--color-white);
    padding-left: 4px;
  }

  /* Bottom bar */
  .footer-bottom {
    padding: 1.5rem 0;
    border-top: 1px solid rgba(255,255,255,0.05);
  }

  .footer-bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer-copyright {
    font-size: var(--text-xs);
    color: var(--color-neutral-600);
  }

  .footer-legal-links {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .footer-legal-links a {
    font-size: var(--text-xs);
    color: var(--color-neutral-500);
    transition: color 0.2s ease;
  }

  .footer-legal-links a:hover {
    color: var(--color-white);
  }

  @media (max-width: 1200px) {
    .footer-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .footer-brand {
      grid-column: 1 / -1;
      flex-direction: row;
      flex-wrap: wrap;
      gap: 2rem;
    }

    .footer-cta {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 480px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }

    .footer-cta-actions {
      flex-direction: column;
      width: 100%;
    }

    .footer-cta-btn {
      width: 100%;
      justify-content: space-between;
    }
  }
</style>
