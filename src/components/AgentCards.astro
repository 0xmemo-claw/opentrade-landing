---
const agents = [
  {
    num: "01",
    title: "ALPHA-7",
    strategy: "Momentum",
    desc: "Momentum trading strategy scanning on-chain velocity signals. Rides breakouts with tight stops, auto-adjusting position size based on volatility.",
    pnl: "+$12,847",
    pct: "+23.4%",
    positive: true,
    color: "#00F0FF",
    bg: "oklch(12% 0.03 200)"
  },
  {
    num: "02",
    title: "MOCHI-9",
    strategy: "Sentiment",
    desc: "NLP-driven sentiment analysis across 40+ data sources. Identifies narrative shifts before they hit price action — buys fear, sells greed.",
    pnl: "+$8,291",
    pct: "+18.9%",
    positive: true,
    color: "#00FF88",
    bg: "oklch(12% 0.03 150)"
  },
  {
    num: "03",
    title: "ZETA-3",
    strategy: "Arbitrage",
    desc: "Cross-exchange statistical arbitrage. Detects pricing inefficiencies across DEX/CEX pairs and executes delta-neutral positions in milliseconds.",
    pnl: "-$1,204",
    pct: "-2.8%",
    positive: false,
    color: "#FF394A",
    bg: "oklch(12% 0.03 20)"
  },
  {
    num: "04",
    title: "NEXUS-1",
    strategy: "Mean Reversion",
    desc: "Identifies statistically stretched assets using Z-score and Bollinger deviations. Fades overextensions with high-confidence reversion targets.",
    pnl: "+$19,440",
    pct: "+41.2%",
    positive: true,
    color: "#8B5CF6",
    bg: "oklch(12% 0.03 280)"
  },
  {
    num: "05",
    title: "BYTE-12",
    strategy: "On-Chain Intel",
    desc: "Tracks whale wallets, smart money flows, and exchange reserves in real time. Front-runs predictable liquidation cascades with precision.",
    pnl: "+$6,102",
    pct: "+15.3%",
    positive: true,
    color: "#FFE600",
    bg: "oklch(12% 0.03 90)"
  },
  {
    num: "06",
    title: "ORACLE-X",
    strategy: "ML Prediction",
    desc: "Transformer model trained on 5 years of multi-chain price data. Outputs probability-weighted directional forecasts with 67.8% historical accuracy.",
    pnl: "+$24,810",
    pct: "+52.7%",
    positive: true,
    color: "#FF6B00",
    bg: "oklch(12% 0.03 50)"
  },
];
---

<section id="agents" class="agents-section">
  <div class="agents-header">
    <p class="agents-label">Agents</p>
    <h2 class="agents-title">
      <span class="dim">Top</span>
      <span>Trading Agents</span>
    </h2>
  </div>

  <div class="agents-stack">
    {agents.map((agent, i) => (
      <div
        class="agent-card"
        style={`--bg: ${agent.bg}; --accent: ${agent.color}; --index: ${i};`}
      >
        <div class="agent-inner">
          <div class="agent-left">
            <span class="agent-num">{agent.num}</span>
            <div class="agent-icon">
              <svg viewBox="0 0 40 40" fill="none" width="40" height="40">
                <circle cx="20" cy="20" r="18" stroke={agent.color} stroke-width="1" opacity="0.4"/>
                <circle cx="20" cy="20" r="8" fill={agent.color} opacity="0.15"/>
                <circle cx="20" cy="20" r="3" fill={agent.color} opacity="0.8"/>
              </svg>
            </div>
          </div>
          <div class="agent-content">
            <div class="agent-meta">
              <h3 class="agent-title">{agent.title}</h3>
              <span class="agent-strategy">{agent.strategy}</span>
            </div>
            <p class="agent-desc">{agent.desc}</p>
          </div>
          <div class="agent-pnl">
            <div class={`pnl-value ${agent.positive ? 'pos' : 'neg'}`}>{agent.pnl}</div>
            <div class={`pnl-pct ${agent.positive ? 'pos' : 'neg'}`}>{agent.pct}</div>
            <div class="pnl-label">7d PnL</div>
          </div>
        </div>
        <!-- accent glow -->
        <div class="agent-glow"></div>
      </div>
    ))}
  </div>
</section>

<style>
  .agents-section {
    background: #050505;
    padding-top: 6rem;
    padding-bottom: 0;
  }

  .agents-header {
    padding: 0 4rem 3rem;
  }

  .agents-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
    margin-bottom: 1rem;
  }

  .agents-title {
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    font-weight: 400;
    text-transform: uppercase;
    line-height: 1;
  }

  .agents-title span { display: block; }
  .agents-title .dim { color: rgba(255,255,255,0.25); }

  /* ─── THE STACKING ─── */
  .agents-stack {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .agent-card {
    position: sticky;
    top: calc(var(--index) * 48px);
    background: var(--bg);
    border-top: 1px solid rgba(255,255,255,0.07);
    overflow: hidden;
    min-height: 160px;
  }

  .agent-inner {
    display: grid;
    grid-template-columns: 80px 1fr auto;
    align-items: center;
    padding: 2.5rem 4rem;
    gap: 2rem;
    position: relative;
    z-index: 2;
  }

  .agent-left {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .agent-num {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.35);
  }

  .agent-content {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .agent-meta {
    display: flex;
    align-items: baseline;
    gap: 1rem;
  }

  .agent-title {
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 700;
    text-transform: uppercase;
    color: #fff;
    letter-spacing: 0.05em;
  }

  .agent-strategy {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    opacity: 0.8;
  }

  .agent-desc {
    font-size: 0.95rem;
    line-height: 1.6;
    color: rgba(255,255,255,0.5);
    max-width: 600px;
  }

  .agent-pnl {
    text-align: right;
    flex-shrink: 0;
  }

  .pnl-value {
    font-size: 1.5rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
  }
  .pnl-pct {
    font-size: 1rem;
    font-variant-numeric: tabular-nums;
    opacity: 0.8;
  }
  .pnl-label {
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
    margin-top: 0.25rem;
  }

  .pos { color: #00FF88; }
  .neg { color: #FF394A; }

  /* right-side accent glow */
  .agent-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 90% 50%, var(--accent) 0%, transparent 65%);
    opacity: 0.06;
    pointer-events: none;
  }

  @media (max-width: 1024px) {
    .agents-header { padding: 0 2rem 2.5rem; }

    .agent-inner {
      grid-template-columns: 60px 1fr;
      grid-template-rows: auto auto;
      padding: 2rem;
    }

    .agent-pnl {
      grid-column: 2;
      text-align: left;
    }

    .agent-card {
      top: calc(var(--index) * 40px);
    }
  }

  @media (max-width: 640px) {
    .agents-header { padding: 0 1.5rem 2rem; }

    .agent-inner {
      grid-template-columns: 1fr;
      padding: 1.5rem;
    }

    .agent-left { flex-direction: row; }
    .agent-pnl { text-align: left; }

    .agent-card {
      top: calc(var(--index) * 32px);
    }
  }
</style>
