---
const agents = [
  {
    name: "Alpha-7",
    strategy: "Momentum",
    pnl7d: "+$12,847",
    pnlPct: "+23.4%",
    positive: true,
    tvl: "$84.2k",
    winRate: "71%",
    trades: 342,
    token: "ALPHA7",
    tokenPrice: "$0.042",
    color: "#00F0FF",
    sparkline: [40, 45, 42, 55, 60, 58, 72, 68, 80, 85, 82, 95],
  },
  {
    name: "Mochi-9",
    strategy: "Sentiment",
    pnl7d: "+$8,291",
    pnlPct: "+18.9%",
    positive: true,
    tvl: "$52.1k",
    winRate: "65%",
    trades: 218,
    token: "MOCHI9",
    tokenPrice: "$0.018",
    color: "#00FF88",
    sparkline: [30, 35, 40, 38, 55, 50, 65, 70, 68, 85, 90, 88],
  },
  {
    name: "Zeta-3",
    strategy: "Arbitrage",
    pnl7d: "-$1,204",
    pnlPct: "-2.8%",
    positive: false,
    tvl: "$31.7k",
    winRate: "58%",
    trades: 891,
    token: "ZETA3",
    tokenPrice: "$0.009",
    color: "#FF394A",
    sparkline: [70, 68, 72, 65, 60, 55, 58, 52, 48, 50, 47, 45],
  },
  {
    name: "Nexus-1",
    strategy: "Mean Reversion",
    pnl7d: "+$19,440",
    pnlPct: "+41.2%",
    positive: true,
    tvl: "$121.8k",
    winRate: "74%",
    trades: 156,
    token: "NEX1",
    tokenPrice: "$0.091",
    color: "#8B5CF6",
    sparkline: [50, 60, 55, 75, 80, 78, 90, 95, 100, 105, 110, 118],
  },
  {
    name: "Byte-12",
    strategy: "On-Chain Intel",
    pnl7d: "+$6,102",
    pnlPct: "+15.3%",
    positive: true,
    tvl: "$48.3k",
    winRate: "68%",
    trades: 274,
    token: "BYTE12",
    tokenPrice: "$0.031",
    color: "#FFE600",
    sparkline: [45, 48, 52, 50, 60, 65, 63, 70, 75, 72, 80, 85],
  },
  {
    name: "Oracle-X",
    strategy: "ML Prediction",
    pnl7d: "+$24,810",
    pnlPct: "+52.7%",
    positive: true,
    tvl: "$198.4k",
    winRate: "79%",
    trades: 89,
    token: "ORACLX",
    tokenPrice: "$0.142",
    color: "#FF6B00",
    sparkline: [60, 70, 75, 80, 85, 95, 100, 105, 115, 125, 130, 140],
  },
];
---

<section id="agents" class="agents-section section">
  <div class="container">
    <div class="agents-header" data-reveal>
      <h2 class="agents-title">
        <span class="title-line">Top</span>
        <span class="title-line title-highlight">Trading Agents</span>
      </h2>
    </div>

    <div class="agents-items">
      {agents.map((agent, i) => (
        <div class="agent-card" data-reveal style={`--item-bg: #0a0a0a; --item-accent: ${agent.color}`}>
          <div class="agent-card-inner">
            <div class="agent-top">
              <div class="agent-avatar-block">
                <div class="agent-icon">
                  <svg viewBox="0 0 60 60" fill="none">
                    <polygon points="30,5 55,50 5,50" stroke={agent.color} stroke-width="2" fill="none" opacity="0.5"/>
                    <polygon points="30,15 45,45 15,45" fill={agent.color} opacity="0.2"/>
                  </svg>
                </div>
                <p class="agent-num">{String(i + 1).padStart(2, '0')}</p>
              </div>
              <div class="agent-info">
                <div class="agent-name-row">
                  <h3 class="agent-name">{agent.name}</h3>
                  <div class="strategy-badge" style={`background: ${agent.color}18; color: ${agent.color}; border: 1px solid ${agent.color}40`}>{agent.strategy}</div>
                </div>
                <!-- Sparkline Chart -->
                <div class="agent-chart">
                  <svg class="sparkline" viewBox={`0 0 ${(agent.sparkline.length - 1) * 20} 50`} preserveAspectRatio="none">
                    <defs>
                      <linearGradient id={`grad-${i}`} x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%" stop-color={agent.color} stop-opacity="0.4"/>
                        <stop offset="100%" stop-color={agent.color} stop-opacity="0"/>
                      </linearGradient>
                    </defs>
                    <path
                      d={`M0,${50 - (agent.sparkline[0] / 140) * 50} ${agent.sparkline.map((v, idx) => `L${idx * 20},${50 - (v / 140) * 50}`).join(' ')} L${(agent.sparkline.length - 1) * 20},50 L0,50 Z`}
                      fill={`url(#grad-${i})`}
                    />
                    <polyline
                      points={agent.sparkline.map((v, idx) => `${idx * 20},${50 - (v / 140) * 50}`).join(' ')}
                      fill="none"
                      stroke={agent.color}
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                    <circle
                      cx={(agent.sparkline.length - 1) * 20}
                      cy={50 - (agent.sparkline[agent.sparkline.length - 1] / 140) * 50}
                      r="3"
                      fill={agent.color}
                    />
                  </svg>
                </div>
                <!-- Stats Row -->
                <div class="agent-stats">
                  <div class="stat-mini">
                    <div class="stat-mini-label">TVL</div>
                    <div class="stat-mini-value mono">{agent.tvl}</div>
                  </div>
                  <div class="stat-mini">
                    <div class="stat-mini-label">Win Rate</div>
                    <div class="stat-mini-value mono" style={`color:${agent.color}`}>{agent.winRate}</div>
                  </div>
                  <div class="stat-mini">
                    <div class="stat-mini-label">Trades</div>
                    <div class="stat-mini-value mono">{agent.trades}</div>
                  </div>
                </div>
                <!-- Token Info -->
                <div class="agent-token">
                  <span class="token-badge mono">{agent.token}</span>
                  <span class="token-price mono" style={`color:${agent.color}`}>{agent.tokenPrice}</span>
                </div>
              </div>
            </div>
            <div class="agent-pnl">
              <div class={`pnl-value mono ${agent.positive ? 'positive' : 'negative'}`}>{agent.pnl7d}</div>
              <div class={`pnl-pct mono ${agent.positive ? 'positive' : 'negative'}`}>{agent.pnlPct}</div>
            </div>
            <div class="agent-symbol">
              <svg viewBox="0 0 100 100" fill="none">
                <polygon points="50,5 95,95 5,95" stroke={agent.color} stroke-width="1.5" fill="none"/>
                <polygon points="50,25 75,75 25,75" fill={agent.color} opacity="0.15"/>
              </svg>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .agents-section {
    background: var(--color-neutral-950);
    padding-top: var(--padding-3xl);
    padding-bottom: var(--padding-3xl);
  }

  .agents-header {
    margin-bottom: var(--gap-2xl);
  }

  .agents-title {
    font-size: var(--text-8xl);
    line-height: var(--leading-normal);
    font-weight: 400;
    text-transform: uppercase;
  }

  .title-line {
    display: block;
    color: rgba(255,255,255,0.3);
  }

  .title-highlight {
    color: var(--color-white);
  }

  .agents-items {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .agent-card {
    background: var(--item-bg, #0a0a0a);
    border: 1px solid rgba(255,255,255,0.05);
    position: relative;
    overflow: hidden;
    clip-path: polygon(
      0% 0%,
      100% 0%,
      100% calc(100% - 30px),
      calc(100% - 30px) 100%,
      0% 100%
    );
    transition: background 0.3s ease;
  }

  .agent-card:hover {
    border-color: rgba(255,255,255,0.1);
  }

  .agent-card-inner {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    padding: var(--padding-xl) var(--padding-2xl);
    position: relative;
    z-index: 2;
    gap: var(--gap-xl);
  }

  .agent-top {
    display: flex;
    flex: 1;
    gap: var(--gap-xl);
  }

  .agent-avatar-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
    width: clamp(3rem, 5vw, 5rem);
  }

  .agent-icon {
    width: clamp(2.5rem, 4vw, 4rem);
    height: clamp(2.5rem, 4vw, 4rem);
  }

  .agent-icon svg {
    width: 100%;
    height: 100%;
  }

  .agent-num {
    font-size: var(--text-xs);
    color: var(--color-neutral-400);
    font-weight: 600;
    letter-spacing: 0.1em;
  }

  .agent-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .agent-name-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .agent-name {
    font-size: var(--text-3xl);
    font-weight: 700;
    text-transform: uppercase;
    color: var(--color-white);
  }

  .strategy-badge {
    font-size: 0.65rem;
    font-weight: 600;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .agent-chart {
    width: 100%;
    height: 60px;
    border-radius: 6px;
    overflow: hidden;
    background: rgba(0,0,0,0.3);
  }

  .sparkline {
    width: 100%;
    height: 100%;
    display: block;
  }

  .agent-stats {
    display: flex;
    gap: 1rem;
    max-width: 320px;
  }

  .stat-mini {
    text-align: center;
    padding: 0.5rem 0.75rem;
    background: rgba(0,0,0,0.3);
    border-radius: 6px;
    border: 1px solid rgba(255,255,255,0.06);
    flex: 1;
  }

  .stat-mini-label {
    font-size: 0.6rem;
    color: var(--color-neutral-500);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.2rem;
  }

  .stat-mini-value {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-white);
  }

  .agent-token {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.4rem 0.6rem;
    background: rgba(0,0,0,0.3);
    border-radius: 6px;
    border: 1px solid rgba(255,255,255,0.06);
    max-width: fit-content;
  }

  .token-badge {
    font-size: 0.7rem;
    color: var(--color-neutral-400);
    font-weight: 600;
    letter-spacing: 0.08em;
  }

  .token-price {
    font-size: 0.8rem;
    font-weight: 700;
  }

  .agent-pnl {
    text-align: right;
    flex-shrink: 0;
    padding-top: 0.5rem;
  }

  .pnl-value {
    font-size: var(--text-3xl);
    font-weight: 700;
    margin-bottom: 0.25rem;
  }

  .pnl-value.positive { color: #00FF88; }
  .pnl-value.negative { color: #FF394A; }

  .pnl-pct {
    font-size: var(--text-sm);
    opacity: 0.8;
  }

  .pnl-pct.positive { color: #00FF88; }
  .pnl-pct.negative { color: #FF394A; }

  .agent-symbol {
    width: clamp(4rem, 7vw, 7rem);
    height: clamp(4rem, 7vw, 7rem);
    flex-shrink: 0;
    opacity: 0.4;
    transition: opacity 0.3s ease;
  }

  .agent-symbol svg {
    width: 100%;
    height: 100%;
  }

  .agent-card:hover .agent-symbol {
    opacity: 0.7;
  }

  /* Item accent glow */
  .agent-card::before {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 40%;
    height: 100%;
    background: radial-gradient(ellipse at 80% 50%, var(--item-accent, transparent) 0%, transparent 70%);
    opacity: 0.08;
    pointer-events: none;
  }

  @media (max-width: 1024px) {
    .agent-card-inner {
      padding: var(--padding-xl);
    }

    .agent-top {
      flex-direction: column;
      gap: 1rem;
    }

    .agent-avatar-block {
      flex-direction: row;
      width: auto;
    }

    .agent-symbol {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .agent-card-inner {
      flex-direction: column;
      padding: 1.5rem;
    }

    .agent-name {
      font-size: var(--text-2xl);
    }

    .agent-stats {
      flex-wrap: wrap;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  
  // Stagger the agent items on scroll (EXACT Avax Why pattern)
  const items = document.querySelectorAll('.agent-card');
  
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const el = entry.target as HTMLElement;
        const idx = Array.from(items).indexOf(el);
        gsap.from(el, {
          x: -50,
          opacity: 0,
          duration: 0.8,
          delay: idx * 0.1,
          ease: 'power3.out'
        });
        observer.unobserve(el);
      }
    });
  }, { threshold: 0.2 });
  
  items.forEach(item => observer.observe(item));
</script>
