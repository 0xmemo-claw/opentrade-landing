---
---

<section class="powered-section section" data-reveal>
  <div class="container">
    <div class="powered-content">
      <div class="powered-visual">
        <!-- Full dark red background block -->
        <div class="powered-block">
          <div class="powered-inner">
            <h3 data-reveal data-reveal-delay="1">Powered by Avalanche</h3>
            <p data-reveal data-reveal-delay="2">
              The future of blockchain adoption won't happen on one chain—it'll happen across thousands of purpose-built L1s. Avalanche is where they're built.
            </p>
            <a href="/powered-by-avax" class="arrow-btn" data-reveal data-reveal-delay="3">
              Learn more
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .powered-section {
    background: var(--color-dark);
    overflow: hidden;
    padding: var(--padding-4xl) 0;
  }

  .powered-content {
    display: flex;
    align-items: stretch;
    min-height: 400px;
  }

  .powered-visual {
    width: 100%;
    position: relative;
  }

  .powered-block {
    width: 100%;
    min-height: 380px;
    background: #1a0202;
    position: relative;
    overflow: hidden;
    clip-path: polygon(
      0% 0%,
      100% 0%,
      100% calc(100% - 40px),
      calc(100% - 40px) 100%,
      0% 100%
    );
  }

  .powered-block::before {
    content: '';
    position: absolute;
    inset: 0;
    background: 
      radial-gradient(ellipse at 80% 50%, rgba(255, 57, 74, 0.25) 0%, transparent 60%),
      radial-gradient(ellipse at 20% 80%, rgba(255, 57, 74, 0.1) 0%, transparent 50%);
  }

  .powered-block::after {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 60%;
    height: 200%;
    background: linear-gradient(90deg, transparent 0%, rgba(255, 57, 74, 0.08) 50%, transparent 100%);
    transform: rotate(15deg);
  }

  .powered-inner {
    position: relative;
    z-index: 2;
    padding: var(--padding-2xl);
    max-width: 600px;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .powered-inner h3 {
    font-size: var(--text-5xl);
    font-weight: 400;
    text-transform: uppercase;
    color: var(--color-white);
    line-height: var(--leading-normal);
  }

  .powered-inner p {
    font-size: var(--text-xl);
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.5;
    max-width: 50ch;
  }

  .arrow-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-white);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: gap 0.3s ease;
  }

  .arrow-btn::after {
    content: '→';
    color: var(--color-red);
    font-size: 1.2em;
    transition: transform 0.3s ease;
  }

  .arrow-btn:hover::after {
    transform: translateX(4px);
  }

  .arrow-btn:hover {
    gap: 1rem;
  }

  @media (max-width: 768px) {
    .powered-inner {
      padding: var(--padding-xl);
    }
  }
</style>
