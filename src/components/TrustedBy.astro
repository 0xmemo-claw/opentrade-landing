---
const logos = [
  { name: "Republic", abbr: "R" },
  { name: "BlackRock", abbr: "BR" },
  { name: "Kinexys", abbr: "K" },
  { name: "Citi", abbr: "C" },
  { name: "Off The Grid", abbr: "OTG" },
  { name: "Gunzilla", abbr: "G" },
  { name: "MapleStory", abbr: "MS" },
  { name: "Beam", abbr: "B" },
  { name: "LFJ", abbr: "LFJ" },
  { name: "Benqi", abbr: "BQ" },
  { name: "GoGoPool", abbr: "GGP" },
  { name: "DEXALOT", abbr: "DX" },
  { name: "Uniswap", abbr: "UNI" },
  { name: "Euler", abbr: "EUL" },
  { name: "Aave", abbr: "AAVE" },
  { name: "Pharaoh", abbr: "PH" },
  { name: "Zeroone", abbr: "01" },
  { name: "Tixbase", abbr: "TX" },
  { name: "SITickets", abbr: "SI" },
];
---

<section class="trusted-section section" data-reveal>
  <div class="container">
    <div class="trusted-header" data-reveal>
      <h2 class="trusted-title">Avalanche is Trusted by Businesses Worldwide</h2>
      <p class="trusted-desc">
        Founders, developers and business leaders across the globe chose Avalanche for their digital asset operations, backed by a reliable, enterprise-grade blockchain network.
      </p>
    </div>

    <!-- Marquee logos -->
    <div class="logos-marquee" id="logos-marquee">
      <div class="logos-track">
        {[...logos, ...logos].map(logo => (
          <div class="logo-pill">
            <span class="logo-abbr">{logo.abbr}</span>
            <span class="logo-name">{logo.name}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .trusted-section {
    background: #050505;
    padding: var(--padding-3xl) 0;
    overflow: hidden;
  }

  .trusted-header {
    text-align: center;
    margin-bottom: var(--gap-2xl);
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }

  .trusted-title {
    font-size: var(--text-5xl);
    font-weight: 400;
    text-transform: uppercase;
    color: var(--color-white);
    margin-bottom: 1.5rem;
    line-height: var(--leading-normal);
  }

  .trusted-desc {
    font-size: var(--text-xl);
    color: var(--color-neutral-400);
    line-height: 1.6;
  }

  /* Marquee */
  .logos-marquee {
    overflow: hidden;
    position: relative;
    margin: 0 calc(-1 * var(--padding-xl));
    padding: 1.5rem 0;
  }

  .logos-marquee::before,
  .logos-marquee::after {
    content: '';
    position: absolute;
    top: 0;
    width: 15%;
    height: 100%;
    z-index: 2;
    pointer-events: none;
  }

  .logos-marquee::before {
    left: 0;
    background: linear-gradient(90deg, #050505, transparent);
  }

  .logos-marquee::after {
    right: 0;
    background: linear-gradient(-90deg, #050505, transparent);
  }

  .logos-track {
    display: flex;
    align-items: center;
    gap: 1rem;
    width: max-content;
    animation: marquee 40s linear infinite;
    will-change: transform;
  }

  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .logos-marquee:hover .logos-track {
    animation-play-state: paused;
  }

  .logo-pill {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border: 1px solid rgba(255,255,255,0.08);
    background: rgba(255,255,255,0.02);
    white-space: nowrap;
    flex-shrink: 0;
    transition: border-color 0.2s ease, background 0.2s ease;
    clip-path: polygon(
      0% 0%,
      calc(100% - 8px) 0%,
      100% 8px,
      100% 100%,
      0% 100%
    );
  }

  .logo-pill:hover {
    border-color: rgba(255,255,255,0.15);
    background: rgba(255,255,255,0.04);
  }

  .logo-abbr {
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-red);
    letter-spacing: 0.1em;
    min-width: 1.5rem;
    text-align: center;
  }

  .logo-name {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-neutral-300);
    letter-spacing: 0.02em;
  }
</style>
