---
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "OpenTrade — Autonomous AI Trading Agents",
  description = "Deploy AI agents that trade crypto 24/7. No emotions, pure alpha. Each agent has its own token with automatic buyback mechanics on Base.",
  ogImage = "/og-image.png"
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#030712" />

  <title>{title}</title>
  <meta name="description" content={description} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://opentrade-landing.vercel.app" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@0xxmemo" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Preconnect fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <!-- Global CSS -->
  <link rel="stylesheet" href="/src/styles/global.css" />

  <style>
    /* ─── Reveal Mask CSS (global) ── */
    .reveal-mask {
      overflow: hidden;
      display: block;
    }
    .reveal-text {
      display: block;
      will-change: transform;
    }
    /* Clip-path reveal for section labels */
    .clip-reveal {
      display: inline-block;
      will-change: clip-path;
    }
    /* Horizontal scroll container */
    .h-scroll-track {
      display: flex;
      will-change: transform;
    }
  </style>
</head>
<body>
  <slot />
</body>
</html>

<script>
  // Lenis smooth scroll init
  // Using UMD version loaded inline to avoid module path issues
  (async () => {
    try {
      // Dynamically import Lenis
      const { default: Lenis } = await import('@studio-freight/lenis');
      
      const lenis = new Lenis({
        duration: 1.2,
        easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        smooth: true,
        smoothTouch: false,
      });

      // Store globally for GSAP ScrollTrigger integration
      (window as any)._lenis = lenis;

      // RAF loop
      function raf(time: number) {
        lenis.raf(time);
        requestAnimationFrame(raf);
      }
      requestAnimationFrame(raf);

      // Dispatch event so components can use ScrollTrigger with lenis
      window.dispatchEvent(new CustomEvent('lenis-ready', { detail: lenis }));
    } catch (e) {
      console.warn('Lenis init failed, using native scroll', e);
      window.dispatchEvent(new CustomEvent('lenis-ready', { detail: null }));
    }
  })();
</script>
